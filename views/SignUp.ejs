<html lang="en">
<%- include("./partials/head.ejs") %>

    <body>
        <%- include("./partials/nav.ejs") %>

            <section class="Log-Sign">
                <div class="form-box">
                    <div class="form-value">
                        <form action="/SignUp" method="post">
                            <h2>Sign Up</h2>
                            <div class="inputbox">
                                <ion-icon name="person-outline"></ion-icon>
                                <input type="text" name="first_name" placeholder="" required>
                                <label>First Name</label>
                            </div>
                            <div class="inputbox">
                                <ion-icon name="person-outline"></ion-icon>
                                <input type="text" name="last_name" placeholder="" required>
                                <label>Last Name</label>
                            </div>
                            <div class="inputbox">
                                <ion-icon name="mail-outline"></ion-icon>
                                <input type="email" name="email" placeholder="" required>
                                <label>Email</label>
                            </div>
                            <div class="inputbox">
                                <ion-icon name="lock-closed-outline"></ion-icon>
                                <input type="password" name="password" placeholder="" required>
                                <label>Password</label>
                            </div>
                            <button type="submit">Sign Up</button>
                            <div style="text-align: center; margin: 15px 0; color: #777; font-weight: bold;">
                                <span>OR</span>
                            </div>
                            <a href="/auth/google"
                                style="display: flex; align-items: center; justify-content: center; background: #fff; color: #333; border: 1px solid #ccc; text-decoration: none; border-radius: 40px; padding: 10px; font-weight: 600; width: 100%; margin-bottom: 20px;">
                                <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/auth/google.svg"
                                    alt="Google" style="width: 20px; margin-right: 10px;">
                                Sign up with Google
                            </a>
                            <div class="register">
                                <p>Already have an account? <a href="/Login">Login</a></p>
                            </div>
                        </form>
                    </div>
                </div>
            </section>
            <script type="module" src="https://unpkg.com/ionicons@5.0.0/dist/ionicons/ionicons.esm.js"></script>
    </body>

</html>